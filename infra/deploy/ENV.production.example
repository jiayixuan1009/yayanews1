# 复制为服务器上的 .env（勿提交 Git）。站点：yayanews.cryptooptiontool.com

NEXT_PUBLIC_SITE_URL=https://yayanews.cryptooptiontool.com
NEXT_PUBLIC_PARENT_SITE=https://www.biyapay.com
NEXT_PUBLIC_TRADING_SITE=https://invest.biyapay.com

# 统计（填好后务必重新 npm run build）
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_BING_UET_ID=
# NEXT_PUBLIC_MS_CLARITY_ID=
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# NEXT_PUBLIC_BING_SITE_VERIFICATION=

# Admin 等若代码中有读取请按需补充，例如：
# ADMIN_TOKEN=...

# Pipeline（同机跑 Python 时在 shell 或 PM2 env 配置）
# SITE_URL=https://yayanews.cryptooptiontool.com
# FINNHUB_KEY=
# 栏目含 AI资讯，slug=ai，列表页 /news/ai；见 pipeline/category_config.py

# LLM：Deepseek（兼容 OpenAI 格式，见 pipeline/llm_config.py）
# LLM_API_KEY=          # Deepseek API Key
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat

# 文章封面：信源 og:image + 图库/生图（pipeline；密钥只放服务器 .env，勿提交）
# 勿使用 NEXT_PUBLIC_；泄露后请在各控制台轮换 Key。
# PEXELS_API_KEY=
# UNSPLASH_ACCESS_KEY=     # 拉图常用
# UNSPLASH_SECRET_KEY=     # 仅 OAuth/需保密接口时使用，勿进前端
# UNSPLASH_APPLICATION_ID= # 若 SDK 要求再填
# PIXABAY_API_KEY=         # https://pixabay.com/api/docs/
# 文生图（可选，Pexels/Unsplash 都失败时尝试 OpenAI Images，图片写入 public/covers/generated/）
# OPENAI_API_KEY=
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_IMAGE_MODEL=dall-e-3
# OPENAI_IMAGE_SIZE=1792x1024
# COVER_IMAGE_GEN=1
# COVER_IMAGE_GEN_PROVIDER=openai
